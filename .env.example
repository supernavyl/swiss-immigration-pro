# ===========================================
# Swiss Immigration Pro - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database ---
DB_NAME=swiss_immigration
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password_here

# --- Auth ---
# Shared by backend AND Next.js API routes — must be identical
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# --- App ---
APP_URL=http://localhost
ADMIN_EMAIL=admin@swissimmigrationpro.com
DEBUG=false

# --- Stripe (payments) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Email (Resend) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Swiss Immigration Pro <noreply@swissimmigrationpro.com>

# --- AI Providers (at least one required for chatbot) ---
GROQ_API_KEY=gsk_...
GOOGLE_GEMINI_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
HUGGINGFACE_API_KEY=
DEEPSEEK_API_KEY=

# --- Monitoring ---
SENTRY_DSN=

# --- Stripe Price IDs (optional, defaults to test IDs) ---
# STRIPE_PRICE_IMMIGRATION_MONTHLY=price_...
# STRIPE_PRICE_IMMIGRATION_ANNUAL=price_...
# STRIPE_PRICE_ADVANCED_MONTHLY=price_...
# STRIPE_PRICE_ADVANCED_ANNUAL=price_...
# STRIPE_PRICE_CITIZENSHIP_MONTHLY=price_...
# STRIPE_PRICE_CITIZENSHIP_ANNUAL=price_...
