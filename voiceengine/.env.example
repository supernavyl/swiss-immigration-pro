# ──────────────────────────────────────────────
# Voice Engine — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# Only the providers you actually use require valid keys.

# ── API Keys ──────────────────────────────────
# OpenAI API key (for GPT models and Whisper API)
OPENAI_API_KEY=

# Anthropic API key (for Claude models)
ANTHROPIC_API_KEY=

# Google AI API key (for Gemini models)
GOOGLE_API_KEY=

# Groq API key (for Groq-hosted models)
GROQ_API_KEY=

# Deepgram API key (for Deepgram STT)
DEEPGRAM_API_KEY=

# ElevenLabs API key (for ElevenLabs TTS)
ELEVENLABS_API_KEY=

# TabbyAPI admin key (optional — only if you set one in TabbyAPI config)
TABBY_API_KEY=

# ── STT (Speech-to-Text) ─────────────────────
# Provider: faster_whisper | openai | deepgram
STT_PROVIDER=faster_whisper

# Model name passed to the STT provider
STT_MODEL=base.en

# ── LLM (Large Language Model) ────────────────
# Provider: ollama | openai | claude | groq | tabby | llamacpp
LLM_PROVIDER=ollama

# Model name passed to the LLM provider
LLM_MODEL=llama3.2

# Base URL for OpenAI-compatible APIs
# Ollama: http://localhost:11434  (default)
# TabbyAPI: http://localhost:5000/v1
# llama.cpp: http://localhost:8080/v1
LLM_BASE_URL=http://localhost:11434

# ── TTS (Text-to-Speech) ─────────────────────
# Provider: kokoro | edge_tts | elevenlabs
TTS_PROVIDER=kokoro

# Voice identifier passed to the TTS provider
TTS_VOICE=af_heart

# ── VAD (Voice Activity Detection) ───────────
# Speech detection confidence threshold (0.0–1.0)
VAD_THRESHOLD=0.5

# Minimum speech duration in ms before it counts as speech
MIN_SPEECH_MS=200

# Minimum silence duration in ms before speech is considered finished
MIN_SILENCE_MS=800

# ── System Prompt ─────────────────────────────
# Optional custom system prompt for the LLM.
# If empty, a default conversational assistant prompt is used.
SYSTEM_PROMPT=
