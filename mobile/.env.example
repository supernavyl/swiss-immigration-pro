# Mobile App Configuration

# ============================================
# DEVELOPMENT MODE (Local Testing)
# ============================================
# Uncomment for local testing
# EXPO_PUBLIC_API_URL=http://localhost:8000
# EXPO_PUBLIC_CONTENT_URL=http://localhost:3000

# ============================================
# PRODUCTION MODE (With Cloudflare)
# ============================================
# Uncomment for production and replace with your domains

# Domain settings
EXPO_PUBLIC_DOMAIN=yourdomain.com
EXPO_PUBLIC_API_DOMAIN=api.yourdomain.com

# Direct URLs (optional - config.ts will auto-detect)
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com
# EXPO_PUBLIC_CONTENT_URL=https://yourdomain.com

# ============================================
# IMPORTANT: How to Use
# ============================================
# 1. For development on your local machine:
#    - Leave config.ts auto-detection enabled
#    - localhost URLs will be used automatically
#
# 2. For production with Cloudflare:
#    - Set EXPO_PUBLIC_DOMAIN=yourdomain.com
#    - Set EXPO_PUBLIC_API_DOMAIN=api.yourdomain.com
#    - config.ts will auto-generate HTTPS URLs
#
# 3. For manual override:
#    - Set EXPO_PUBLIC_API_URL=https://your-custom-api.com
#    - Set EXPO_PUBLIC_CONTENT_URL=https://your-custom-content.com

# ============================================
# Advanced Configuration (Optional)
# ============================================

# Enable detailed logging
# DEBUG=true

# Custom timeouts (in milliseconds)
# API_TIMEOUT=30000

# Feature flags
# ENABLE_ANALYTICS=true
# ENABLE_CRASH_REPORTING=true
